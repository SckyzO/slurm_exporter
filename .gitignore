bin/
dist/
go/
*.snap
*.tar.gz*
*.swp

# Binary staged by `make docker-build` under ./linux/<arch>/ (the
# $TARGETPLATFORM layout the Dockerfiles COPY from). The Makefile rm's it
# after each build but git should never see it either way. /slurm_exporter
# is the legacy path, kept ignored for safety.
/slurm_exporter
/linux/

# Dev/test scripts (environment-specific, not committed)
scripts/dev/

# Claude instructions file
CLAUDE.md

# Local cluster config override (machine-specific)
scripts/testing/cluster.local.conf

# Local scratch space — survive reboots (unlike /tmp) but never committed.
# Useful for draft issue comments, release-PR bodies, exporter capture
# files, etc. Only .gitkeep and the README are committed, so the directory
# and its convention are visible on a fresh clone.
tmp/*
!tmp/.gitkeep
!tmp/README.md

# Claude Code session state
.claude/
