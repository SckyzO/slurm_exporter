bin/
dist/
go/
*.snap
*.tar.gz*
*.swp

# Dev/test scripts (environment-specific, not committed)
scripts/dev/

# Screenshots: ignore all temporary ones, keep only documentation screenshots
# (named <dashboard>-<N>.png, e.g. overview-1.png, jobs-2.png)
dashboards_grafana/screenshots/*
!dashboards_grafana/screenshots/accounting-*.png
!dashboards_grafana/screenshots/overview-*.png
!dashboards_grafana/screenshots/jobs-*.png
!dashboards_grafana/screenshots/nodes-*.png
!dashboards_grafana/screenshots/usage-*.png
!dashboards_grafana/screenshots/scheduler-*.png
!dashboards_grafana/screenshots/health-*.png
!dashboards_grafana/screenshots/reservations-*.png
!dashboards_grafana/screenshots/exporter-perf-*.png

# Claude instructions file
CLAUDE.md

# Local cluster config override (machine-specific)
scripts/testing/cluster.local.conf

# Local scratch space — survive reboots (unlike /tmp) but never committed.
# Useful for draft issue comments, release-PR bodies, exporter capture
# files, etc. Only .gitkeep and the README are committed, so the directory
# and its convention are visible on a fresh clone.
tmp/*
!tmp/.gitkeep
!tmp/README.md

# Claude Code session state
.claude/
