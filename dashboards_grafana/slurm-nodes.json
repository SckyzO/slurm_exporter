    {
      "type": "row",
      "id": 101,
      "title": "CPU & Memory Utilization per Node",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "table",
      "id": 10,
      "title": "Node CPU & Memory Detail",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CPU %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Mem %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Mem Alloc (GB)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Mem Total (GB)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "mixed": {
                        "color": "yellow",
                        "text": "mixed"
                      },
                      "idle": {
                        "color": "green",
                        "text": "idle"
                      },
                      "allocated": {
                        "color": "orange",
                        "text": "alloc"
                      },
                      "down": {
                        "color": "red",
                        "text": "down"
                      },
                      "reserved": {
                        "color": "blue",
                        "text": "resv"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "node": "Node",
              "partition": "Partition",
              "status": "Status",
              "Value #A": "CPU Alloc",
              "Value #B": "CPU Total",
              "Value #C": "CPU %",
              "Value #D": "Mem Alloc (GB)",
              "Value #E": "Mem Total (GB)",
              "Value #F": "Mem %",
              "Value #G": "Up"
            },
            "indexByName": {
              "Node": 0,
              "Partition": 1,
              "Status": 2,
              "CPU Alloc": 3,
              "CPU Total": 4,
              "CPU %": 5,
              "Mem Alloc (GB)": 6,
              "Mem Total (GB)": 7,
              "Mem %": 8
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_cpu_alloc",
          "legendFormat": "{{node}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_cpu_total",
          "legendFormat": "{{node}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_cpu_alloc / slurm_node_cpu_total * 100",
          "legendFormat": "{{node}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_mem_alloc / 1024",
          "legendFormat": "{{node}}",
          "refId": "D",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_mem_total / 1024",
          "legendFormat": "{{node}}",
          "refId": "E",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_mem_alloc / slurm_node_mem_total * 100",
          "legendFormat": "{{node}}",
          "refId": "F",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_node_status",
          "legendFormat": "{{node}}",
          "refId": "G",
          "instant": true,
          "format": "table"
        }
      ]
